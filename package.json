{
  "name": "geinosky.github.io",
  "version": "1.0.0",
  "description": "Portfolio",
  "main": "index.js",
  "scripts": {
    "library:clean": "del-cli assets/library",
    "library:fontawesome": "mkdir -p assets/libraries/fontawesome && cp -R node_modules/@fortawesome/fontawesome-free/* assets/libraries/fontawesome/",
    "library:bootstrap": "mkdir -p assets/libraries/bootstrap && cp -R node_modules/bootstrap/dist/* assets/libraries/bootstrap/",
    "library:build": "npm run library:clean && npm run library:fontawesome && npm run library:bootstrap"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geinosky/geinosky.github.io.git"
  },
  "author": "Stephen Geinosky",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/geinosky/geinosky.github.io/issues"
  },
  "homepage": "https://github.com/geinosky/geinosky.github.io#readme",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "bootstrap": "^5.3.8"
  },
  "devDependencies": {
    "del-cli": "^7.0.0"
  }
}
